#!/bin/zsh

# Set target directory from argument or default to current
TARGET_DIR="${1:-.}"

# Ensure target is a directory
if [[ ! -d "$TARGET_DIR" ]]; then
  echo "Error: $TARGET_DIR is not a directory"
  exit 1
fi

# Generate timestamp
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")

# Compress each subdirectory
find "$TARGET_DIR" -mindepth 1 -maxdepth 1 -type d | while read -r dir; do
  base=$(basename "$dir")
  archive="${dir}_${TIMESTAMP}.tar.gz"
  if [[ -f "$archive" ]]; then
    echo "Skipping existing archive: $archive"
  else
    echo "Compressing directory: $dir -> $archive"
    tar -czf "$archive" -C "$(dirname "$dir")" "$base"
  fi
done

# Compress each .sql file
find "$TARGET_DIR" -mindepth 1 -maxdepth 1 -type f -name "*.sql" | while read -r sql; do
  base=$(basename "$sql")
  archive="${sql}_${TIMESTAMP}.tar.gz"
  if [[ -f "$archive" ]]; then
    echo "Skipping existing archive: $archive"
  else
    echo "Compressing SQL file: $sql -> $archive"
    tar -czf "$archive" -C "$(dirname "$sql")" "$base"
  fi
done